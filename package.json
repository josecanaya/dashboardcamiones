{
  "name": "truck-route-simulator",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:live": "pnpm run seed:live && pnpm run dev",
    "seed:live": "cd simulador && npm run simulate -- --scenario=live --reset && npm run simulate -- --scenario=live",
    "seed:march_full": "node simulador/scripts/seed-march-full.cjs",
    "diversify:march_full": "node simulador/scripts/diversify-march-durations.cjs",
    "simulator:live": "cd simulador && npm run simulate:start -- --scenario=live --intervalSec=3",
    "simulator:live:fg": "cd simulador && npm run simulate:foreground -- --scenario=live --intervalSec=3",
    "simulator:live:turbo": "cd simulador && npm run simulate:foreground -- --scenario=live --intervalSec=0.12",
    "simulator:reset:turbo": "cd simulador && npx tsx src/index.ts --scenario=live --reset && npm run simulate:foreground -- --scenario=live --intervalSec=0.12",
    "simulator:reset:live": "cd simulador && npx tsx src/index.ts --scenario=live --reset && npm run simulate:foreground -- --scenario=live --intervalSec=5",
    "simulator:stop": "cd simulador && npm run simulate:stop",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "framer-motion": "^11.11.17",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.7.0",
    "three": "^0.183.2",
    "web-ifc-three": "^0.0.126",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "~5.6.2",
    "vite": "^5.4.10",
    "vitest": "^4.0.18"
  }
}
